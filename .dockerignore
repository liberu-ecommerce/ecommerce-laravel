# Without this file, `COPY . .` (Dockerfile:143) copies whatever the builder
# happens to have in their working tree straight into the image. CI clones fresh
# so it never noticed, but a local `docker build` broke outright:
#
#   In ProviderRepository.php line 205:
#     Class "Laravel\Pail\PailServiceProvider" not found
#
# ...because a local bootstrap/cache/packages.php lists dev packages while the
# image's autoloader is --no-dev. Same class of problem for vendor/ and .env.

# Reinstalled --no-dev in the composer-deps stage and copied in at Dockerfile:137.
# Copying the local one over it puts dev dependencies in a production image.
/vendor

# The image builds no assets (no npm step), so node_modules is 174MB of nothing.
/node_modules

# Regenerated by `composer dump-autoload` inside the image. Copying the host's
# is what broke the local build: it names dev providers the --no-dev autoloader
# cannot resolve. The .gitignore in that directory must survive so the directory
# itself still exists.
/bootstrap/cache/*.php

# Dockerfile:170 overwrites .env with .env.example, but COPY . . has already
# written the real one into an earlier layer by then — and layers are readable
# from the image history. Secrets do not go in.
.env
.env.*
!.env.example

/.git
/.github
/.idea
/.vscode

/storage/logs/*
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*.php
/public/storage

/tests
/.phpunit.cache
/.phpunit.result.cache

Dockerfile
.dockerignore
docker-compose*.yml
*.md
